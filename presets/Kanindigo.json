    "tokenColors": [
      {
        "name": "Comment",
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#6E656C",
          "fontStyle": ""
        }
      },
      {
        "name": "Variable",
        "scope": [
          "variable",
          "string constant.other.placeholder"
        ],
        "settings": {
          "foreground": "#CDC1B4",
          "fontStyle": ""
        }
      },
      {
        "name": "Color",
        "scope": [
          "constant.other.color"
        ],
        "settings": {
          "foreground": "#ED9069",
          "fontStyle": ""
        }
      },
      {
        "name": "Invalid",
        "scope": [
          "invalid",
          "invalid.illegal"
        ],
        "settings": {
          "foreground": "#D8202D",
          "fontStyle": ""
        }
      },
      {
        "name": "Storage - Type",
        "scope": [
          "storage.type"
        ],
        "settings": {
          "foreground": "#8E73B3",
          "fontStyle": ""
        }
      },
      {
        "name": "Storage - Modifier",
        "scope": [
          "storage.modifier"
        ],
        "settings": {
          "foreground": "#8E73B3",
          "fontStyle": ""
        }
      },
      {
