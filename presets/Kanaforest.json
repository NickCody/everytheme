    "tokenColors": [
      {
        "name": "Comment",
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#89A595",
          "fontStyle": ""
        }
      },
      {
        "name": "Variable",
        "scope": [
          "variable",
          "string constant.other.placeholder"
        ],
        "settings": {
          "foreground": "#DCE9E1",
          "fontStyle": ""
        }
      },
      {
        "name": "Color",
        "scope": [
          "constant.other.color"
        ],
        "settings": {
          "foreground": "#7DC79B",
          "fontStyle": ""
        }
      },
      {
        "name": "Invalid",
        "scope": [
          "invalid",
          "invalid.illegal"
        ],
        "settings": {
          "foreground": "#FF6678",
          "fontStyle": ""
        }
      },
      {
        "name": "Storage - Type",
