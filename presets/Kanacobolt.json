    "tokenColors": [
      {
        "name": "Comment",
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#7F8AA8",
          "fontStyle": ""
        }
      },
      {
        "name": "Variable",
        "scope": [
          "variable",
          "string constant.other.placeholder"
        ],
        "settings": {
          "foreground": "#D6DEEE",
          "fontStyle": ""
        }
      },
      {
        "name": "Color",
        "scope": [
          "constant.other.color"
        ],
        "settings": {
          "foreground": "#6EA8FF",
          "fontStyle": ""
        }
      },
      {
        "name": "Invalid",
        "scope": [
          "invalid",
          "invalid.illegal"
        ],
        "settings": {
          "foreground": "#FF5470",
          "fontStyle": ""
        }
      },
      {
        "name": "Storage - Type",
        "scope": [
          "storage.type"
        ],
        "settings": {
          "foreground": "#6B74D6",
          "fontStyle": ""
        }
      },
      {
        "name": "Storage - Modifier",
        "scope": [
          "storage.modifier"
        ],
        "settings": {
          "foreground": "#6B74D6",
          "fontStyle": ""
        }
      },
      {
