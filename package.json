{
  "name": "everytheme",
  "displayName": "Everytheme",
  "description": "AI-powered VS Code theme that changes on the fly via natural language",
  "version": "0.2.7",
  "publisher": "everytheme",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/NickCody/everytheme"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Everytheme",
        "uiTheme": "vs-dark",
        "path": "./themes/everytheme-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "everytheme.chat",
        "title": "Everytheme: Change Theme with AI"
      },
      {
        "command": "everytheme.selectTheme",
        "title": "Everytheme: Select Theme"
      },
      {
        "command": "everytheme.selectProvider",
        "title": "Everytheme: Select AI Provider"
      },
      {
        "command": "everytheme.reset",
        "title": "Everytheme: Reset to Default"
      },
      {
        "command": "everytheme.configureProvider",
        "title": "Everytheme: Configure API Keys & Endpoints"
      },
      {
        "command": "everytheme.newConversation",
        "title": "Everytheme: New Chat Conversation"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "everytheme",
          "title": "Everytheme",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "everytheme": [
        {
          "type": "webview",
          "id": "everytheme.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Everytheme",
      "properties": {
        "everytheme.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (overrides ANTHROPIC_API_KEY env var)"
        },
        "everytheme.anthropicBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Anthropic API base URL (overrides ANTHROPIC_BASE_URL env var)"
        },
        "everytheme.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (overrides OPENAI_API_KEY env var)"
        },
        "everytheme.openaiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "OpenAI API base URL (overrides OPENAI_BASE_URL env var)"
        },
        "everytheme.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API key (overrides GEMINI_API_KEY / GOOGLE_API_KEY env var)"
        },
        "everytheme.geminiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Gemini API base URL (overrides GOOGLE_API_BASE_URL env var)"
        },
        "everytheme.provider": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai",
            "gemini"
          ],
          "default": "",
          "description": "Preferred AI provider (auto-detected from env vars if not set)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && npm run compile:prod",
    "compile": "rm -rf out && node scripts/build.mjs && node scripts/copy-assets.mjs",
    "compile:prod": "rm -rf out && node scripts/build.mjs --production && node scripts/copy-assets.mjs",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc -p ./ --noEmit",
    "package": "rm -f everytheme-*.vsix && vsce package",
    "package:install": "rm -f everytheme-*.vsix && vsce package && code --install-extension everytheme-*.vsix --force",
    "update-color-keys": "node scripts/generate-color-keys.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "marked": "^12.0.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.0",
    "openai": "^4.82.0"
  }
}
